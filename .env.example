# AWS Bedrock Configuration
# Inference runs against the Bedrock runtime Converse API. Authenticate with EITHER a
# Bedrock API key (bearer token, Option A) OR standard AWS SigV4 credentials (Option B).

# Option A — Bedrock API key (bearer token). Create one in the Bedrock console.
AWS_BEARER_TOKEN_BEDROCK=ABSKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B — AWS SigV4 credentials (IAM access keys / a profile / an IAM role).
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Region must match the model_id's inference-profile geo (eu.* -> an EU region,
# us.* -> a US region). Not every model is offered in every region — verify with
# ListFoundationModels for the target region before running.
AWS_REGION=eu-north-1

# NOTE: Enable model access for this account and region in the Bedrock console before
# running. Anthropic Claude Haiku 4.5 is available in eu-north-1 (eu.* inference
# profile); Meta Llama and Mistral Large 3 are NOT offered in eu-north-1.

# Optional: Logging configuration
# LOG_LEVEL=INFO
# LOG_FILE=outputs/logs/experiment.log

# Optional: Output directory
# OUTPUT_DIR=outputs
